# ============================================================
# HOUSEHOLD AI - Environment Variables
# Copy this file to .env.local and fill in your values.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# All others are server-only.
# ============================================================

# -------------------------------------------------------
# REQUIRED: Supabase
# Get these from your Supabase project > Settings > API
# -------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# WARNING: Never expose this key client-side. Server/API routes only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -------------------------------------------------------
# OPTIONAL: OpenAI
# Leave OPENAI_API_KEY unset (or set AI_ENABLED=false) to
# run the app with zero AI cost. All features still work.
# -------------------------------------------------------
AI_ENABLED=false
# Uncomment and set your key to enable AI features:
# OPENAI_API_KEY=sk-proj-...
# Cheapest model that works well for this use case:
OPENAI_MODEL=gpt-4o-mini
# Hard cap on output tokens per AI call. 300 = ~3-4 sentences.
# Raising this increases cost proportionally.
OPENAI_MAX_TOKENS=300
# Max AI calls per household per day (both users combined).
# 3 = ~$0.02/month. 10 = ~$0.06/month. Keep low.
AI_MAX_CALLS_PER_DAY=3

# -------------------------------------------------------
# REQUIRED: App URL
# Used for OAuth redirects and invite link generation.
# -------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# -------------------------------------------------------
# OPTIONAL: Web Push Notifications (disabled by default)
# Generate keys with: npx web-push generate-vapid-keys
# -------------------------------------------------------
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com

# -------------------------------------------------------
# OPTIONAL: Docker build flag
# Set automatically by Dockerfile - do not set manually.
# -------------------------------------------------------
# DOCKER_BUILD=true
